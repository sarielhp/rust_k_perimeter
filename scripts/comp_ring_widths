#!/bin/bash

# Ensure output/annulus exists
mkdir -p output/annulus

# Function to process a single file
# Matching the logic in scripts/compute_annulus_width.jl to determine output names
process_one() {
    input_file="$1"
    
    # base_name = replace(basename(input_file), r"\.[^.]+$" => "")
    base_name=$(basename "$input_file")
    base_name_no_ext="${base_name%.*}"
    
    # final_name = "a_" * replace(base_name_no_ext, "_poly" => "")
    final_name="a_${base_name_no_ext//_poly/}"
    
    output_pdf="output/annulus/${final_name}.pdf"
    output_txt="output/annulus/${final_name}.txt"

    # Run only if output files are missing or input file is newer than output files
    if [[ ! -f "$output_pdf" || ! -f "$output_txt" || "$input_file" -nt "$output_pdf" || "$input_file" -nt "$output_txt" ]]; then
        scripts/compute_annulus_width.jl "$input_file"
    fi
}

export -f process_one

# Run in parallel using all available threads. 
# find output/polys/ -type f -name "*.txt" returns files like output/polys/000010_poly.txt
# xargs -P 0 runs as many processes as possible simultaneously (based on available cores if specified)
# Using $(nproc) ensures it uses all available hardware threads.
find output/polys/ -type f -name "*.txt" -print0 | xargs -0 -I {} -n 1 -P $(nproc) bash -c 'process_one "$@"' _ {}
