#!/bin/bash

# Directory containing summary files
SUMMARY_DIR="output/summary"

# Check if directory exists
if [ ! -d "$SUMMARY_DIR" ]; then
    echo "Directory $SUMMARY_DIR not found."
    exit 1
fi

# Iterate through files matching the pattern
for file in "$SUMMARY_DIR"/*_s.txt; do
    [ -e "$file" ] || continue
    
    # Extract the number from the filename (e.g., 000100_s.txt -> 100)
    filename=$(basename "$file")
    number_full="${filename%_s.txt}"
    # Strip leading zeros
    number=$(echo "$number_full" | sed 's/^0*//')
    # If it was all zeros, set it to 0
    if [ -z "$number" ]; then
        number="0"
    fi
    
    # Check if the file already has the "k :" line
    # We check for both with and without '#' just in case
    if grep -qE "^(# )?k[[:space:]]*:" "$file"; then
        # Already has it, skip
        continue
    fi
    
    # Create the new line. 
    # Label is "k". We want 29 characters before ":".
    # "# k" is 3 chars. 29 - 3 = 26 spaces.
    new_line=$(printf "# k%-26s: %s" "" "$number")
    
    # Prepend the new line to the file
    # We use a temporary file to be safe
    tmp_file=$(mktemp)
    echo "$new_line" > "$tmp_file"
    cat "$file" >> "$tmp_file"
    mv "$tmp_file" "$file"
    
    echo "Updated $file with k : $number"
done
