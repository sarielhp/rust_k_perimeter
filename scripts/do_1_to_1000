#! /bin/bash

run_if_missing() {
    local target_file="$1"
    local command_to_run="$2"

    # -e checks if the file exists (including directories)
    # Use -f if you specifically want to check for a regular file
    if [[ ! -e "$target_file" ]]; then
        echo "File '$target_file' not found. Executing: $command_to_run"
        eval "$command_to_run"
    else
        echo "File '$target_file' already exists. Skipping command."
    fi
}

parse_int() {
    # Remove all underscores from the input string
    local clean_num="${1//_/}"
    
    # Check if the result is actually a valid integer
    if [[ "$clean_num" =~ ^-?[0-9]+$ ]]; then
        echo "$clean_num"
    else
        echo "Error: '$1' is not a valid integer" >&2
        return 1
    fi
}

function  run_on() {
    num=$(parse_int $1)
    echo $num
    FL=$(printf "output/summary/%06d_s.txt" $num)

    if  [[ -e $FL ]]; then
        return
    fi

    echo -e "\n\n\n\n\n\n"
    echo "k: $num"
    cargo run --release  -- $num
#    echo $FL
}

for i in {3..10000}
do
   echo "Number: $i"
   run_on         $i
done

