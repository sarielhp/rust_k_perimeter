#! /bin/bash

# Configuration
ANNULUS_DIR="output/annulus"
SUMMARY_DIR="output/summary"
SEARCH_STRING="annulus width"
THREADS=$(nproc 2>/dev/null || echo 4)

# Function to merge a single annulus file into its summary file
# Exported for use with xargs/bash -c
merge_one() {
    local annulus_file="$1"
    
    # Extract the number from the filename (e.g., a_000010.txt -> 000010)
    local base=$(basename "$annulus_file")
    local num=$(echo "$base" | sed 's/^a_\([0-9]*\)\.txt$/\1/')
    
    # Corresponding summary file path
    local summary_file="$SUMMARY_DIR/${num}_s.txt"
    
    # Check if target file exists
    [ -f "$summary_file" ] || return 0
    
    # Only append if summary is newer than annulus file (as requested)
    # Note: This prevents merging if the annulus file was updated AFTER the summary file.
    [ "$summary_file" -nt "$annulus_file" ] || return 0
    
    # Check if "annulus width" is already in the summary file to avoid duplicate merging
    grep -q "$SEARCH_STRING" "$summary_file" && return 0
    
    # Concatenate
    echo "Merging $annulus_file into $summary_file"
    cat "$annulus_file" >> "$summary_file"
}

export -f merge_one
export SUMMARY_DIR SEARCH_STRING

# Find all relevant .txt files and process them in parallel
# Using xargs with -P for parallel execution
find "$ANNULUS_DIR" -maxdepth 1 -name "a_[0-9]*.txt" -print0 | \
    xargs -0 -P "$THREADS" -I {} bash -c 'merge_one "$@"' _ {}
