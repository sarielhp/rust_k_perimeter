#! /bin/bash

# Configuration
ANNULUS_DIR="output/annulus"
SUMMARY_DIR="output/summary"
SEARCH_STRING="annulus width"

# Iterate over all .txt files in the annulus directory
# Format: output/annulus/a_000010.txt
for annulus_file in "$ANNULUS_DIR"/a_[0-9]*.txt; do
    # Check if any files matched the pattern
    [ -e "$annulus_file" ] || continue
    
    # Extract the number from the filename (e.g., a_000010.txt -> 000010)
    # Using basename and then sed to remove "a_" and ".txt"
    base=$(basename "$annulus_file")
    num=$(echo "$base" | sed 's/^a_\([0-9]*\)\.txt$/\1/')
    
    # Corresponding summary file path
    # According to prompt/previous context, files in summary/ are <number>_s.txt
    summary_file="$SUMMARY_DIR/${num}_s.txt"
    
    # Check if target file exists
    if [ ! -f "$summary_file" ]; then
        # If the file with _s.txt doesn't exist, check if the prompt meant _s_.txt literally
        # But our check showed _s.txt is what exists.
        # We'll skip if the target doesn't exist.
        continue
    fi
    
    # Check if "annulus width" is already in the summary file
    if grep -q "$SEARCH_STRING" "$summary_file"; then
        # Already concatenated
        continue
    fi
    
    # Concatenate
    echo "Merging $annulus_file into $summary_file"
    cat "$annulus_file" >> "$summary_file"
done
