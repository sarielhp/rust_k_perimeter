#!/bin/bash

# Check if k is provided
if [ -z "$1" ]; then
    echo "Usage: $0 <k>"
    exit 1
fi

K=$1
STRATEGIES=("ng_perim_dto" "ng_perim" "perim_ng" "perim_ng_dtog" "ng_dto" "ng_idx" "perim_idx" "topo_ng")

echo "Building project in release mode..."
cargo build --release --quiet

echo "Comparing queuing strategies for k=$K..."
echo "--------------------------------------------------------------------------"
printf "%-20s | %-15s | %-15s\n" "Strategy" "Time (s)" "Configs"
echo "--------------------------------------------------------------------------"

MIN_TIME=999999
BEST_STRAT=""

for STRAT in "${STRATEGIES[@]}"; do
    # Run the program and capture output
    # Using the compiled binary directly for speed
    OUTPUT=$(./target/release/rust_k_perimeter "$K" --queue="$STRAT" 2>/dev/null)
    
    # Extract time and configs using grep and sed
    TIME=$(echo "$OUTPUT" | grep "Running time in seconds" | sed 's/.*:[[:space:]]*//' | awk '{print $1}')
    CONFIGS=$(echo "$OUTPUT" | grep "# Configs computed" | sed 's/.*:[[:space:]]*//' | awk '{print $1}')
    
    # Handle cases where the run might fail
    if [ -z "$TIME" ]; then
        printf "%-20s | %-15s | %-15s\n" "$STRAT" "FAILED" "N/A"
        continue
    fi

    printf "%-20s | %-15s | %-15s\n" "$STRAT" "$TIME" "$CONFIGS"
    
    # Comparison using bc for floating point math
    if (( $(echo "$TIME < $MIN_TIME" | bc -l) )); then
        MIN_TIME=$TIME
        BEST_STRAT=$STRAT
    fi
done

echo "--------------------------------------------------------------------------"
if [ -n "$BEST_STRAT" ]; then
    echo "WINNER: $BEST_STRAT with $MIN_TIME seconds"
else
    echo "No strategies completed successfully."
fi
