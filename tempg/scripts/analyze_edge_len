#! /bin/env julial
using Pkg
Pkg.activate(@__DIR__)
using CSV
using DataFrames

function parse_arg(arg)
    try
        # Attempt to parse as a number (e.g., float)
        return parse(Float64, arg)
    catch
        # If it fails, try to evaluate it as a fraction (e.g., "1/6")
        try
            return eval(Meta.parse(arg))
        catch
            error("Could not parse argument: $arg")
        end
    end
end

if length(ARGS) != 3
    println("Usage: analyze_edge_len <A> <C> <B>")
    println("Description:")
    println("  Compares f(k) = ceil(A + C * k^B) to the 'Longest primitive edge len' field")
    println("  in 'misc/extracted_data.csv' for each value of k.")
    println("")
    println("Arguments:")
    println("  A : Constant offset")
    println("  C : Multiplier for the power term")
    println("  B : Exponent for k")
    println("")
    println("Example:")
    println("  ./scripts/analyze_edge_len 10 3/2 1/6")
    println("  This evaluates f(k) = ceil(10 + 1.5 * k^(1/6))")
    exit(1)
end

A = parse_arg(ARGS[1])
C = parse_arg(ARGS[2])
B = parse_arg(ARGS[3])

csv_path = joinpath(@__DIR__, "..", "misc", "extracted_data.csv")
if !isfile(csv_path)
    error("CSV file not found: $csv_path")
end

df = CSV.read(csv_path, DataFrame)

# Filter for rows that have necessary columns
if !all(in.(["k", "Longest primitive edge len"], Ref(names(df))))
    error("CSV must contain 'k' and 'Longest primitive edge len' columns")
end

# Calculate f(k) = ceil(A + C * k^B)
df[!, :fk] = ceil.(A .+ C .* (df.k .^ B))
df[!, :gap] = df.fk .- df."Longest primitive edge len"

is_always_larger = all(df.gap .>= 0)

formula_str = "f(k) = ceil($A + $C * k^($B))"

if is_always_larger
    min_gap = minimum(df.gap)
    min_rel_gap = minimum(df.gap ./ df.fk)
    
    println("$formula_str is ALWAYS larger than or equal to 'Longest primitive edge len'.")
    println("Minimum absolute gap: ", min_gap)
    println("Minimum relative gap: ", min_rel_gap)
else
    violations = df[df.gap .< 0, :]
    println("$formula_str is NOT always larger than 'Longest primitive edge len'.")
    println("Found ", nrow(violations), " violations.")
    # Show the first few violations if needed
    first_v = violations[1, :]
    println("Example violation at k=$(first_v.k): f(k)=$(first_v.fk), real=$(first_v."Longest primitive edge len")")
end

# Statistics for the largest 20 values of k
df_sorted = sort(df, :k, rev=true)
top_20 = first(df_sorted, 20)

top_20_min_gap = minimum(top_20.gap)
top_20_max_gap = maximum(top_20.gap)
top_20_min_rel = minimum(top_20.gap ./ top_20.fk)
top_20_max_rel = maximum(top_20.gap ./ top_20.fk)

println("\nStatistics for the 20 largest values of k:")
println("Range of k: [$(minimum(top_20.k)), $(maximum(top_20.k))]")
println("Absolute gap: [min: $top_20_min_gap, max: $top_20_max_gap]")
println("Relative gap: [min: $top_20_min_rel, max: $top_20_max_rel]")
