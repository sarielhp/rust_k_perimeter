#!/bin/bash

# Check if k is provided
if [ -z "$1" ]; then
    echo "Usage: $0 <k>"
    exit 1
fi

K=$1
RETAIN_FACTORS="1.1 1.2 1.5 1.8 2.0 2.5 3.0 4.0"

# Ensure the binary is built
cargo build --release > /dev/null 2>&1

echo "Benchmarking k=$K with various retain factors..."
echo ""

# Define column headers and widths
format="| %-13s | %-15s | %-16s | %-14s |\n"
divider="|---------------|-----------------|------------------|----------------|"

printf "$format" "Retain Factor" "DP Duration (s)" "Configs Computed" "Total Time (s)"
echo "$divider"

for r in $RETAIN_FACTORS; do
    # Run the solver and capture output
    output=$(./target/release/rust_k_perimeter "$K" --retain "$r" 2>&1)
    
    # Extract values using grep and awk
    dp_duration=$(echo "$output" | grep "DP duration" | awk -F': ' '{print $2}' | xargs)
    configs=$(echo "$output" | grep "Configs computed" | awk -F': ' '{print $2}' | xargs)
    total_time=$(echo "$output" | grep "Running time in seconds" | awk -F': ' '{print $2}' | xargs)
    
    # Format floating point numbers for cleaner display if they are very long
    dp_duration_fmt=$(printf "%.4f" "$dp_duration" 2>/dev/null || echo "$dp_duration")
    total_time_fmt=$(printf "%.4f" "$total_time" 2>/dev/null || echo "$total_time")
    
    printf "$format" "$r" "$dp_duration_fmt" "$configs" "$total_time_fmt"
done
